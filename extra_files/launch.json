{
        "preLaunchTask": "inference_diff_plus_vit_delegate_v9",
        "name": "Inference Diff | VITv9",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceFolder}/bazel-bin/tensorflow/lite/delegates/utils/secda_delegates/vit_delegate/v9/inference_diff_plus_vit_delegate",
        "args": [
            "--model_file=${workspaceFolder}/../data/models/vit_tiny_patch16_224.tflite",
            // "--model_file=${workspaceFolder}/../data/models/deit_tiny_patch16_224.tflite",
            // "--model_file=${workspaceFolder}/../data/models/mobilevit_s_int8.tflite",
            // "--model_file=${workspaceFolder}/../data/models/efficientvit_int8.tflite",
            // "--model_file=${workspaceFolder}/../data/models/Swin-T_INT8.tflite",


            "--num_runs=1",
            "--use_vit_delegate=true",
        ],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb",
        "setupCommands": [
            {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            }
        ]
    },
                {
        "preLaunchTask": "benchmark_model_plus_vit_delegate_v9",
        "name": "Benchmark Model | VITv9",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceFolder}/bazel-bin/tensorflow/lite/delegates/utils/secda_delegates/vit_delegate/v9/benchmark_model_plus_vit_delegate",
        "args": [
            "--use_gpu=false",
            "--num_threads=1",
            "--enable_op_profiling=true",
            "--graph=${workspaceFolder}/../data/models/vit_tiny_patch16_224.tflite",
            "--num_runs=1",
            "--warmup_runs=0",
            "--use_vit_delegate=true",
            "--print_postinvoke_state=true"
        ],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb",
        "setupCommands": [
            {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            }
        ]
    }